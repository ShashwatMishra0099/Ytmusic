# ════════════════════════════════════════════════════════
#  Telegram VC Bot — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#    nano .env
#
#  NEVER commit .env to Git — it contains secrets.
#  .env is already listed in .gitignore.
# ════════════════════════════════════════════════════════

# ── Telegram Bot Token ───────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# ── Target Group Chat ID ─────────────────────────────────
# The group where the bot operates (negative number for groups/supergroups)
# To find it: forward a message from the group to @userinfobot
GROUP_CHAT_ID=-1001234567890

# ── Telegram API Credentials (for the secondary/userbot account) ─
# Get from https://my.telegram.org → API Development Tools
API_ID=12345678
API_HASH=your_api_hash_here

# ── Pyrogram Session String (secondary account) ──────────
# Generate with: python3 gen_session.py
# Must be from the SECONDARY account that will join the VC
SESSION_STR=your_session_string_here

# ── Optional: override default file paths ────────────────
# SILENCE_WAV=silence.wav
# CACHE_DIR=cache
